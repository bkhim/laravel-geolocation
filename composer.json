{
  "name": "bkhim/laravel-geolocation",
  "version": "4.1.2",
  "description": "Laravel geolocation with built-in fraud prevention, risk scoring, MFA triggers, and security event monitoring. 5 providers, proxy/VPN/Tor detection, login tracking, timezone/currency personalization for Laravel 10-12",
  "keywords": ["geolocation", "ip", "location", "laravel", "fraud-prevention", "security", "risk-scoring", "mfa", "proxy-detection", "vpn-detection", "tor", "login-tracking", "timezone", "currency", "maxmind", "ipinfo", "ipstack", "ipgeolocation"],
  "homepage": "https://github.com/bkhim/laravel-geolocation",
  "license": "MIT",
  "authors": [
    {
      "name": "Brian Kimathi",
      "email": "brian@briankimathi.com",
      "homepage": "https://briankimathi.com/packages/laravel-geolocation"
    }
  ],
  "minimum-stability": "dev",
  "require": {
    "php": "^8.2",
    "ext-openssl": "*",
    "ext-json": "*",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "guzzlehttp/guzzle": "^6.0|^7.0",
    "geoip2/geoip2": "^v3.3.0"
  },
    "require-dev": {
        "orchestra/testbench": "^6.0|^7.0|^8.0|^9.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0"
    },
  "autoload-dev": {
    "psr-4": {
      "Bkhim\\Geolocation\\Tests\\": "tests/"
    }
  },
  "suggest": {
    "ext-maxminddb": "For better performance with MaxMind databases"
  },
  "scripts": {
    "test": "vendor/bin/phpunit"
  },
  "conflict": {
    "adrianorsouza/laravel-geolocation": "*"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Bkhim\\Geolocation\\GeolocationServiceProvider"
      ],
      "aliases": {
        "GeoLocation": "Bkhim\\Geolocation\\GeoLocation",
        "IpAnonymizer": "Bkhim\\Geolocation\\Facades\\IpAnonymizer",
        "LocationConsentManager": "Bkhim\\Geolocation\\Facades\\LocationConsentManager"
      }
    }
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
